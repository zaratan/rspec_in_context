  "license": "MIT",
  "devDependencies": {
    "@prettier/plugin-ruby": "^4.0",
    "prettier": "^3.8.1"
  },
  "prettier": {
    "trailingComma": "es5",
    "plugins": [
      "@prettier/plugin-ruby"
    ],
    "overrides": [
      {
